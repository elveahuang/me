{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "jsx": "react-jsx",
        "paths": {
            "#/*": ["./src/*"],
            "@/*": ["./src/*"]
        },
        "strict": true,
        "types": ["vite/client"]
    },
    "extends": "./base.json",
    "include": ["**/*.ts", "**/*.tsx"]
}
