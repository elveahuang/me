{
    "extends": "@repo/config/typescript/tsr.json",
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["void/env", "vite/client"],
        "jsx": "preserve",
        "baseUrl": ".",
        "paths": {
            "@commons/core/*": ["../commons/src/*"],
            "@/*": ["./src/*"],
            "void/db": ["./.void/db.d.ts"],
            "@schema": ["./db/schema.ts"],
            "@schema/*": ["./db/schema/*"],
            "void/routes": ["./.void/routes.d.ts"]
        }
    },
    "include": ["src", "pages", "routes", "middleware", "crons", "queues", "db"],
    "files": ["./.void/routes.d.ts", "./.void/db.d.ts"]
}
