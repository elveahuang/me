{
    "name": "repo",
    "version": "26.1.0",
    "scripts": {
        "start:native:dev": "pnpm run --filter @apps/native dev",
        "build:native:dev": "pnpm run --filter @apps/native build",
        "start:server:migrate": "pnpm run --filter @apps/server generate:payload:migrate",
        "start:server:generate": "pnpm run --filter @apps/server generate:payload:types",
        "start:server:generate:importmap": "pnpm run --filter @apps/server generate:payload:importmap",
        "start:server:dev": "pnpm run --filter @apps/server dev",
        "build:server:dev": "pnpm run --filter @apps/server build",
        "build:server:pro": "pnpm run --filter @apps/server build",
        "build:server:vercel": "pnpm run --filter @apps/server build",
        "start:webapp:dev": "pnpm run --filter @apps/webapp start:dev",
        "start:webapp:pro": "pnpm run --filter @apps/webapp start:pro",
        "build:webapp:dev": "pnpm run --filter @apps/webapp build:dev",
        "build:webapp:pro": "pnpm run --filter @apps/webapp build:pro",
        "prettier": "prettier --write './**/*.{ts,tsx,mts,js,jsx,cjs,mjs,vue,json,md}'",
        "stylelint": "stylelint './**/*.{css}' --fix"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commons/config": "workspace:*",
        "@eslint/js": "^10.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.1",
        "eslint": "^10.2.0",
        "eslint-config-next": "^16.2.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-html": "^8.1.4",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "path": "^0.12.7",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "stylelint": "^17.6.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-prettier": "^5.0.3",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "typescript-plugin-css-modules": "^5.2.0"
    },
    "packageManager": "pnpm@10.33.0"
