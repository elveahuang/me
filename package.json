{
    "name": "repo",
    "version": "26.1.0",
    "scripts": {
        "start:mobile:dev": "pnpm run --filter @apps/mobile dev",
        "build:mobile:dev": "pnpm run --filter @apps/mobile build",
        "start:server:dev": "pnpm run --filter @apps/server start:dev",
        "start:server:pro": "pnpm run --filter @apps/server start:pro",
        "build:server:dev": "pnpm run --filter @apps/server build:dev",
        "build:server:pro": "pnpm run --filter @apps/server build:pro",
        "build:server:vercel": "pnpm run --filter @apps/server build:vercel",
        "start:webapp:migrate": "pnpm run --filter @apps/webapp generate:payload:migrate",
        "start:webapp:generate": "pnpm run --filter @apps/webapp generate:payload:types",
        "start:webapp:generate:importmap": "pnpm run --filter @apps/webapp generate:payload:importmap",
        "start:webapp:dev": "pnpm run --filter @apps/webapp dev",
        "build:webapp:dev": "pnpm run --filter @apps/webapp build",
        "build:webapp:pro": "pnpm run --filter @apps/webapp build",
        "build:webapp:vercel": "pnpm run --filter @apps/webapp build",
        "start:www:dev": "pnpm run --filter @apps/www start:dev",
        "start:www:pro": "pnpm run --filter @apps/www start:pro",
        "build:www:dev": "pnpm run --filter @apps/www build:dev",
        "build:www:pro": "pnpm run --filter @apps/www build:pro",
        "lint": "eslint './**/*.{ts,tsx,mts,js,jsx,cjs,mjs,vue,json,md}' --fix",
        "format": "prettier --write './**/*.{ts,tsx,mts,js,jsx,cjs,mjs,vue,json,md}'",
        "stylelint": "stylelint './**/*.{css}' --fix"
    },
    "dependencies": {
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.0",
        "@commitlint/config-conventional": "^21.0.0",
        "@commons/config": "workspace:*",
        "@eslint/js": "^10.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.3.0",
        "eslint-config-next": "^16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-html": "^8.1.4",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "path": "^0.12.7",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "stylelint": "^17.11.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-prettier": "^5.0.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "typescript-plugin-css-modules": "^5.2.0"
    },
    "packageManager": "pnpm@11.0.9"
}
